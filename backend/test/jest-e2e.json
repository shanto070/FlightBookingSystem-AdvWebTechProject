{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "testPathIgnorePatterns": [
    "<rootDir>/Adv.-Web-BackEnd/",
    "<rootDir>/Adv.-Web-FrontEnd/",
    "<rootDir>/frontend/"
  ],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "testTimeout": 30000
}
